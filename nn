<!doctype html>
<html lang="ru">
<head>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
<title>AISHA</title>
<style>
:root{--pink:#ff7faf;--hot:#ff5c9d;--dark:#070006;--soft:#ffd1df;--paper:#f4cfd5}
*{box-sizing:border-box;user-select:none;-webkit-tap-highlight-color:transparent}html,body{height:100%;margin:0;background:#000;overflow:hidden;font-family:'Courier New',monospace;color:var(--pink)}
#app{position:fixed;inset:0;background:#000;overflow:hidden}.screen{position:absolute;inset:0;display:grid;place-items:center;opacity:0;pointer-events:none;transition:opacity .55s ease}.screen.active{opacity:1;pointer-events:auto}.black.active{opacity:1;background:#000}.matrix canvas{position:absolute;inset:0;width:100%;height:100%;image-rendering:pixelated}.vignette{position:absolute;inset:0;background:radial-gradient(circle,transparent 35%,rgba(0,0,0,.55) 100%);pointer-events:none}.pixel{position:relative;text-align:center;text-transform:uppercase;font-weight:900;letter-spacing:.08em;color:var(--pink);text-shadow:0 0 6px #ff4d97,0 0 18px #ff2b85;filter:contrast(1.25);animation:glitch .25s infinite steps(2)}.big{font-size:clamp(64px,18vw,160px);line-height:.9}.word{font-size:clamp(42px,11vw,120px);padding:0 18px}.small{font-size:clamp(18px,5vw,30px)}
.pixel::after{content:attr(data-text);position:absolute;inset:0;transform:translate(2px,1px);color:#ffbad0;opacity:.25}.pixel::before{content:attr(data-text);position:absolute;inset:0;transform:translate(-2px,-1px);color:#d82978;opacity:.25}@keyframes glitch{0%,100%{transform:none}50%{transform:translate(1px,-1px)}}
.heart{width:min(34vw,180px);aspect-ratio:1;position:relative;transform:rotate(45deg);background:var(--pink);box-shadow:0 0 0 6px rgba(255,127,175,.15),0 0 28px #ff4f96;image-rendering:pixelated;animation:beat 1.1s infinite}.heart:before,.heart:after{content:"";position:absolute;width:100%;height:100%;background:var(--pink);border-radius:50%}.heart:before{left:-50%}.heart:after{top:-50%}@keyframes beat{50%{transform:rotate(45deg) scale(1.12)}}
.stars{background:#010103}.stars:before,.stars:after{content:"";position:absolute;inset:0;background-image:radial-gradient(#fff 1px,transparent 1.5px),radial-gradient(#fff 1px,transparent 1.5px);background-size:48px 48px,89px 89px;background-position:4px 7px,20px 33px;animation:drift 18s linear infinite;opacity:.9}.stars:after{filter:blur(.3px);transform:scale(1.6);opacity:.45}@keyframes drift{to{background-position:4px 500px,20px 700px}}
.envelope{position:relative;width:min(72vw,330px);height:min(45vw,205px);background:var(--soft);border:3px solid #7b424b;box-shadow:0 0 0 5px rgba(255,209,223,.15),0 0 40px rgba(255,127,175,.25);cursor:pointer}.envelope:before,.envelope:after{content:"";position:absolute;inset:0;background:linear-gradient(32deg,transparent 49%,#7b424b 50%,transparent 51%),linear-gradient(-32deg,transparent 49%,#7b424b 50%,transparent 51%)}.seal{position:absolute;left:50%;top:50%;transform:translate(-50%,-45%) rotate(45deg);width:42px;height:42px;background:#df1c37;box-shadow:0 0 0 4px #ffd5dd}.seal:before,.seal:after{content:"";position:absolute;width:42px;height:42px;background:#df1c37;border-radius:50%}.seal:before{left:-21px}.seal:after{top:-21px}.swipe{position:absolute;bottom:7vh;width:100%;text-align:center;color:var(--pink);font-weight:900;letter-spacing:.12em;text-shadow:0 0 10px #ff5c9d;animation:blink 1s infinite}@keyframes blink{50%{opacity:.45}}
.album{background:#010103}.book{width:min(92vw,720px);height:min(72vh,470px);display:flex;gap:10px;padding:18px;background:linear-gradient(90deg,#e8c0c5,#f6dce0 48%,#c99da3 50%,#f8dfe2 52%,#e3b7bd);border:4px solid #6f464b;border-radius:6px;box-shadow:0 0 0 7px rgba(255,215,224,.13),0 0 45px rgba(255,127,175,.22);position:relative}.page{flex:1;background:#edd0d0;border:2px solid #7b575b;padding:10px;display:grid;place-items:center;overflow:hidden}.page img{width:100%;height:100%;object-fit:cover;border:3px solid #fff3f3;box-shadow:0 0 0 2px #86585f;filter:saturate(.92) contrast(.96)}.book:after{content:"";position:absolute;top:18px;bottom:18px;left:50%;width:3px;background:#8b5a60;box-shadow:0 0 12px rgba(0,0,0,.6)}.nav{position:absolute;inset:0;display:flex}.nav button{flex:1;border:0;background:transparent;color:transparent}.endbook{width:min(65vw,310px);height:min(65vw,380px);background:var(--paper);border:4px solid #745057;box-shadow:0 0 0 8px rgba(255,215,224,.14),0 0 35px rgba(255,127,175,.22);display:grid;place-items:center}.endheart{width:48px;height:48px;background:#df1c37;transform:rotate(45deg);position:relative;box-shadow:0 0 0 5px #ffd5dd}.endheart:before,.endheart:after{content:"";position:absolute;width:48px;height:48px;background:#df1c37;border-radius:50%}.endheart:before{left:-24px}.endheart:after{top:-24px}.hint{position:absolute;bottom:3vh;text-align:center;width:100%;font-size:16px;letter-spacing:.12em;color:var(--pink);font-weight:900;text-shadow:0 0 9px #ff5c9d}
@media(max-width:600px){.book{height:62vh;padding:12px;gap:6px}.page{padding:6px}.word{font-size:clamp(38px,13vw,86px)}}
</style>
</head><body><div id="app">
<section class="screen black active" id="black"></section>
<section class="screen matrix" id="matrix"><canvas id="rain"></canvas><div class="vignette"></div><div id="overlay"></div></section>
<section class="screen stars" id="stars"><div class="envelope" id="env"><div class="seal"></div></div><div class="swipe">SWIPE →</div></section>
<section class="screen album stars" id="album"><div class="book" id="book"><div class="page"><img id="left"></div><div class="page"><img id="right"></div><div class="nav"><button id="prev"></button><button id="next"></button></div></div><div class="hint">SWIPE →</div></section>
<section class="screen stars" id="end"><div class="endbook"><div class="endheart"></div></div><div class="hint">THE END ♥</div></section>
</div><script>
const $=id=>document.getElementById(id);const screens=['black','matrix','stars','album','end'].reduce((a,id)=>(a[id]=$(id),a),{});function show(id){Object.values(screens).forEach(s=>s.classList.remove('active'));screens[id].classList.add('active')}
const canvas=$('rain'),ctx=canvas.getContext('2d');let W,H,cols,drops;function resize(){W=canvas.width=innerWidth*devicePixelRatio;H=canvas.height=innerHeight*devicePixelRatio;ctx.setTransform(devicePixelRatio,0,0,devicePixelRatio,0,0);cols=Math.floor(innerWidth/18);drops=Array.from({length:cols},()=>Math.random()*-80)}addEventListener('resize',resize);resize();
function drawRain(){ctx.fillStyle='rgba(0,0,0,.14)';ctx.fillRect(0,0,innerWidth,innerHeight);ctx.font='900 15px Courier New';ctx.textAlign='center';for(let i=0;i<cols;i++){let x=i*18+9;let y=drops[i]*18;for(let j=0;j<6;j++){let ch='AISHA'[(Math.floor(drops[i]+j))%5];ctx.fillStyle=j===0?'#ffbad0':(i%3?'#ff66a1':'#b91b65');ctx.globalAlpha=j===0?1:.75;ctx.fillText(ch,x,y+j*18)}drops[i]+=0.45+Math.random()*0.22;if(y>innerHeight+120&&Math.random()>.975)drops[i]=Math.random()*-40}ctx.globalAlpha=1;requestAnimationFrame(drawRain)}drawRain();
const overlay=$('overlay');function pixel(txt,cls='word'){overlay.innerHTML=`<div class="pixel ${cls}" data-text="${txt}">${txt}</div>`}function clearText(){overlay.innerHTML=''}
setTimeout(()=>show('matrix'),800);let timeline=[ [1700,'3','big'],[2900,'2','big'],[4100,'1','big'],[5350,"I'M",'word'],[6550,'TRULY','word'],[7750,'SORRY','word'],[8950,'MY','word'],[10150,'LOVE','word'],[11350,'AISHA','word'],[12600,'HEART','heart'] ];timeline.forEach(([t,txt,cls])=>setTimeout(()=>{ if(cls==='heart') overlay.innerHTML='<div class="heart"></div>'; else pixel(txt,cls)},t));setTimeout(()=>{clearText();show('stars')},14200);
$('env').onclick=()=>showAlbum();let photos=['assets/photo1.jpeg','assets/photo2.jpeg','assets/photo3.jpeg','assets/photo4.jpeg','assets/photo5.jpeg','assets/photo6.jpeg'];let spread=0;function render(){let i=spread*2;$('left').src=photos[i];$('right').src=photos[i+1]||photos[i]}function showAlbum(){show('album');spread=0;render()}function go(n){spread+=n;if(spread<0)spread=0;if(spread*2>=photos.length){show('end');return}render()}$('next').onclick=()=>go(1);$('prev').onclick=()=>go(-1);let sx=0;['album','stars'].forEach(id=>$(id).addEventListener('touchstart',e=>sx=e.touches[0].clientX,{passive:true}));$('album').addEventListener('touchend',e=>{let dx=e.changedTouches[0].clientX-sx;if(dx<-30)go(1);if(dx>30)go(-1)});$('stars').addEventListener('touchend',e=>{if(sx-e.changedTouches[0].clientX>25)showAlbum()});
</script></body></html>